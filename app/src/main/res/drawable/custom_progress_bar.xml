<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Latar Belakang Bar (Saat XP Kosong) -->
    <item android:id="@android:id/background">
        <shape>
            <corners android:radius="4dp" />
            <solid android:color="#2D3748" /> <!-- Warna abu-abu gelap -->
        </shape>
    </item>

    <!-- Bar Progress (Warna XP yang Terisi) -->
    <item android:id="@android:id/progress">
        <clip>
            <shape>
                <corners android:radius="4dp" />
                <solid android:color="@color/accent_yellow" /> <!-- Warna Emas -->
            </shape>
        </clip>
    </item>

</layer-list>